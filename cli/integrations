#!/usr/bin/env node
/*
 * integrations (issue #130)
 *
 * Thin client to the Controller server's integrations gateway. Lets an agent
 * discover and use the third-party connections the user configured in the UI,
 * without ever seeing a credential — the server injects auth and makes the
 * outbound call. Invoked by its absolute install path
 * (`~/coding-orchestrator/bin/integrations`) because sanitized/login shells
 * drop injected env vars and PATH entries.
 *
 * Commands:
 *   list                                  Connected integrations for this session.
 *   search <query>                        Fuzzy-search tools across integrations.
 *   tools <integration>                   Tool names for one integration.
 *   describe <integration> <tool>         One tool's schema/usage.
 *   call <integration> <tool> [--json '{...}']   Schema-backed call (MCP/OpenAPI).
 *   request <integration> <METHOD> <path> [--query k=v] [--header k=v] [--data '...']
 *   status <integration>                  whoami / health check.
 *
 * Dependency-free Node script (no build step) so it runs identically in dev and
 * packaged builds.
 */

const USAGE = `Usage:
  integrations list
  integrations search <query>
  integrations tools <integration>
  integrations describe <integration> <tool>
  integrations call <integration> <tool> [--json '{"key":"value"}']
  integrations request <integration> <METHOD> <path> [--query k=v]... [--header k=v]... [--data '<body>']
  integrations status <integration>`;

function fail(message) {
  process.stderr.write(`Error: ${message}\n`);
  process.exit(1);
}

async function getServerUrl() {
  if (process.env.CONTROLLER_SERVER_URL) return process.env.CONTROLLER_SERVER_URL;
  const os = await import("node:os");
  const path = await import("node:path");
  const fs = await import("node:fs/promises");

  const candidates = [];
  try {
    const scriptPath = await fs.realpath(process.argv[1]);
    candidates.push(path.join(path.dirname(scriptPath), "..", "integrations-runtime.json"));
  } catch {}
  if (process.env.CODING_ORCHESTRATOR_HOME) {
    candidates.push(path.join(process.env.CODING_ORCHESTRATOR_HOME, "integrations-runtime.json"));
  }
  candidates.push(path.join(os.homedir(), "coding-orchestrator", "integrations-runtime.json"));

  for (const candidate of candidates) {
    try {
      const parsed = JSON.parse(await fs.readFile(candidate, "utf-8"));
      if (parsed && typeof parsed.serverUrl === "string") return parsed.serverUrl;
    } catch {}
  }
  fail("Could not determine the Controller server URL. Is the Controller app running?");
}

function parsePairs(rest, flag) {
  const out = {};
  for (let i = 0; i < rest.length; i += 1) {
    if (rest[i] === flag && rest[i + 1]) {
      const eq = rest[i + 1].indexOf("=");
      if (eq > 0) out[rest[i + 1].slice(0, eq)] = rest[i + 1].slice(eq + 1);
      i += 1;
    }
  }
  return out;
}

function flagValue(rest, flag) {
  const idx = rest.indexOf(flag);
  return idx >= 0 ? rest[idx + 1] : undefined;
}

function parseArgs(argv) {
  const [command, ...rest] = argv;
  if (!command || command === "-h" || command === "--help") {
    process.stdout.write(`${USAGE}\n`);
    process.exit(command ? 0 : 1);
  }

  switch (command) {
    case "list":
      return { endpoint: "list", body: {} };
    case "search": {
      const query = rest.join(" ").trim();
      if (!query) fail("search requires a <query>");
      return { endpoint: "search", body: { query } };
    }
    case "tools": {
      if (!rest[0]) fail("tools requires an <integration>");
      return { endpoint: "tools", body: { integration: rest[0] } };
    }
    case "describe": {
      if (!rest[0] || !rest[1]) fail("describe requires <integration> <tool>");
      return { endpoint: "describe", body: { integration: rest[0], tool: rest[1] } };
    }
    case "call": {
      if (!rest[0] || !rest[1]) fail("call requires <integration> <tool>");
      const json = flagValue(rest, "--json");
      let args = {};
      if (json) {
        try {
          args = JSON.parse(json);
        } catch {
          fail("--json must be valid JSON");
        }
      }
      return { endpoint: "call", body: { integration: rest[0], tool: rest[1], args } };
    }
    case "request": {
      if (!rest[0] || !rest[1] || !rest[2]) fail("request requires <integration> <METHOD> <path>");
      const data = flagValue(rest, "--data");
      let body = null;
      if (data !== undefined) {
        try {
          body = JSON.parse(data);
        } catch {
          body = data; // send as a raw string when not JSON
        }
      }
      return {
        endpoint: "request",
        body: {
          integration: rest[0],
          method: rest[1],
          path: rest[2],
          query: parsePairs(rest, "--query"),
          headers: parsePairs(rest, "--header"),
          body,
        },
      };
    }
    case "status": {
      if (!rest[0]) fail("status requires an <integration>");
      return { endpoint: "status", body: { integration: rest[0] } };
    }
    default:
      fail(`Unknown command: ${command}\n${USAGE}`);
  }
}

function printResult(command, result) {
  if (command === "list") {
    const conns = result.connections ?? [];
    if (conns.length === 0) return process.stdout.write("No integrations are enabled for this session.\n");
    for (const c of conns) process.stdout.write(`${c.name}  [${c.mode}/${c.kind}]  ${c.summary}\n`);
    return;
  }
  if (command === "search") {
    const matches = result.matches ?? [];
    if (matches.length === 0) return process.stdout.write("No matching tools.\n");
    for (const m of matches) process.stdout.write(`${m.integration}  ${m.tool} — ${m.summary}\n`);
    return;
  }
  if (command === "tools") {
    if (result.note) process.stdout.write(`${result.note}\n`);
    for (const t of result.tools ?? []) process.stdout.write(`${t.tool} — ${t.summary}\n`);
    return;
  }
  if (command === "describe") {
    return process.stdout.write(`${JSON.stringify(result, null, 2)}\n`);
  }
  if (command === "status") {
    process.stdout.write(`${result.message}\n`);
    if (result.ok === false) process.exit(2);
    return;
  }
  // call / request
  if (result.ok === false) {
    if (result.reauth) {
      process.stdout.write(`Re-authentication needed: ${result.reauth.message}\n`);
      process.exit(3);
    }
    fail(result.error || "Request failed");
  }
  if (result.result !== undefined) {
    // MCP call result.
    return process.stdout.write(`${JSON.stringify(result.result, null, 2)}\n`);
  }
  // HTTP ExecResult.
  process.stdout.write(`HTTP ${result.status} ${result.statusText}\n`);
  if (result.body) process.stdout.write(`${result.body}\n`);
  if (result.truncated) process.stdout.write("\n[output truncated]\n");
}

async function main() {
  const { endpoint, body } = parseArgs(process.argv.slice(2));
  const serverUrl = await getServerUrl();

  let response;
  try {
    response = await fetch(`${serverUrl.replace(/\/$/, "")}/api/integrations/gateway/${endpoint}`, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ ...body, cwd: process.cwd() }),
    });
  } catch (error) {
    fail(`Could not reach the orchestrator: ${error?.message ?? error}`);
  }

  let result;
  try {
    result = await response.json();
  } catch {
    fail(`Unexpected response (HTTP ${response.status})`);
  }

  if (response.status >= 400 && result && result.error) fail(result.error);
  printResult(process.argv[2], result);
}

main().catch((error) => fail(error?.message ?? String(error)));
