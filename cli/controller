#!/usr/bin/env node
/*
 * controller — unified Controller CLI for agents (issues #109, #130, #134, #190).
 *
 * One entry point with per-surface subcommands:
 *   controller browser <action> ...        Drive the in-app preview browser.
 *   controller integrations <action> ...   Use configured third-party services.
 *   controller skills <action> ...          Search and activate unified skills.
 *   controller worktrees <action> ...       Manage worktrees on a project.
 *   controller sessions <action> ...        Start a session pinned to a worktree.
 *
 * Invoked by its absolute install path (`<controllerHome>/bin/controller`,
 * resolved from CONTROLLER_HOME or the platform default — see `paths.ts`)
 * because sanitized/login shells drop injected env vars and PATH entries.
 * The server URL comes from CONTROLLER_SERVER_URL when present, otherwise
 * from the runtime file the server publishes next to this script.
 * Dependency-free (no build step) so it runs identically in dev and
 * packaged builds.
 */

const USAGE = `Usage:
  controller browser open <url>
  controller browser snapshot [--a11y] [selector]
  controller browser click <selector>
  controller browser type <selector> <text> [--submit]

  Selectors for click/type (issue #170) accept a plain CSS selector, or a
  locator-style prefix: \`text=...\`, \`role=<role>[name="..."]\`,
  \`label=...\`, \`placeholder=...\`, \`ref=<id>\`. \`ref=<id>\` resolves to an
  element from the most recent \`snapshot\` call — see the \`[ref=eN]\` markers
  the snapshot prints next to interactive elements.

  \`snapshot --a11y\` prints the page as a structured accessibility tree
  (role + accessible name + ref) instead of the default text + interactive
  elements view. Refs are populated in both modes.

  controller terminal list
  controller terminal run <terminalId> <command…>
  controller terminal snapshot <terminalId> [--lines N]
  controller terminal tail <terminalId> [--follow]

  Terminal ids come from \`terminal list\`, which shows the terminals open in
  the current worktree — don't guess them. \`run\` sends a command to a tab the
  user already has open (the user sees it in the Terminals tab); read the
  result with \`snapshot\` (last \`--lines\` lines, default 200) or \`tail\`
  (new output; \`--follow\` streams until interrupted).

  controller integrations list [--all]
  controller integrations search <query>
  controller integrations tools <integration>
  controller integrations describe <integration> <tool>
  controller integrations call <integration> <tool> [--json '{"key":"value"}']
  controller integrations request <integration> <METHOD> <path> [--query k=v]... [--header k=v]... [--data '<body>']
  controller integrations status <integration>
  controller integrations create --name <name> --transport-mode <mode> \\
      [--enabled true|false] \\
      [--transport-config k=v]... [--transport-header k=v]... [--transport-query k=v]... \\
      [--scheme-acquisition <kind> [--scheme-id <id>] \\
          [--scheme-attachment <header|query>:<name> [--scheme-attachment-prefix <prefix>]] \\
          [--scheme-config k=v]... \\
          [--scheme-secret <value> | --scheme-secret=- | --scheme-secret-file <path>]]...

  \`integrations list\` (default) shows active connections in the agent-facing
  gateway view. \`--all\` returns the full registry (active + disabled) — use
  it to inspect an existing connection or grab an id before calling \`create\`.

  \`integrations create\` stands up a new connection in the registry. The
  built-in connections (Notion, Trello, GitHub, …) are read-only from the
  agent's side, so this is how you wire up a custom third-party service and
  then immediately use it through the gateway (\`call\` / \`request\`).

  Each \`--scheme-acquisition\` flag starts a new auth scheme block; everything
  until the next \`--scheme-acquisition\` (or end of args) belongs to it. At
  least one scheme is required. Valid acquisitions: static, basic, oauth,
  oauth_client_credentials, oauth_dynamic, cloud, hmac, mtls. Attachments
  (\`--scheme-attachment header:Authorization\`) are rejected for hmac/mtls/cloud.

  Secrets: prefer \`--scheme-secret-file <path>\` (read once, never echoed) or
  \`--scheme-secret=-\` (read from stdin). \`--scheme-secret <value>\` is also
  accepted but exposes the value to the process list / shell history.

  controller skills list
  controller skills search <query>
  controller skills describe <name>
  controller skills activate <name>
  controller skills create --name <name> --description <description> [--body <body>] [--body-file <path>]
  controller skills import-discover
  controller skills import [--provider <id>] [--source <path>] [--scope <scope>] [--overwrite]... [--all]

  controller worktrees list <project>
  controller worktrees create <project> --name <name> [--branch <branch>] [--base <baseBranch>]
  controller worktrees delete <project> <worktreeId>

  <project> accepts either the project's id (UUID) or its human name. The
  CLI resolves names to ids against the orchestrator's project list.

  controller sessions start <project> --worktree <worktreeId> --message <text> \\
      [--provider codex|claude|anita] [--model <model>] [--mode default|plan] [--skill <name>]

  \`sessions start\` kicks off a new agent run on the given worktree and prints
  a URL the user can open in Controller to follow along. The CLI does not
  stream transcript events; the run is persisted to disk and the UI subscribes
  to the existing event-list endpoint for live updates.

  controller schedules list <project> [--enabled-only]
  controller schedules show <project> <scheduleId>
  controller schedules add <project> --worktree <id> --prompt <text> \\
      [--at <iso>] [--cron <expr>] [--timezone <tz>] \\
      [--every minute|hour|day|weekday] [--on-day <0-6>] [--at-hour <0-23>] [--at-minute <0-59>] \\
      [--provider codex|claude|anita] [--model <id>] [--mode default|plan] \\
      [--enabled true|false] [--source user|agent]
  controller schedules enable <project> <scheduleId>
  controller schedules disable <project> <scheduleId>
  controller schedules remove <project> <scheduleId>
  controller schedules runs <project> <scheduleId>

  \`schedules add\` registers a future session on a worktree. Use \`--at <iso>\`
  for a one-shot run, or \`--cron <expr>\` / \`--every\` for a recurring one.
  \`--every day|weekday\` fires at \`--at-hour\`:\`--at-minute\` (default 09:00) in
  \`--timezone\` (default the server's). The run fires on the next scheduler
  tick after the target time.`;

// Exposed for tests: only auto-run `main()` when this file is the script the
// process was launched as, so unit tests can import the helpers without
// triggering CLI parsing against the test runner's argv.
import { pathToFileURL } from "node:url";
export const isMain =
  process.argv[1] !== undefined &&
  import.meta.url === pathToFileURL(process.argv[1]).href;

function fail(message) {
  process.stderr.write(`Error: ${message}\n`);
  process.exit(1);
}

async function getServerUrl() {
  if (process.env.CONTROLLER_SERVER_URL) return process.env.CONTROLLER_SERVER_URL;
  const os = await import("node:os");
  const path = await import("node:path");
  const fs = await import("node:fs/promises");

  const candidates = [];
  // 1. Sibling to the installed CLI script (most robust handle — survives
  //    env-stripping providers and works regardless of the home's location).
  try {
    const scriptPath = await fs.realpath(process.argv[1]);
    candidates.push(path.join(path.dirname(scriptPath), "..", "controller-runtime.json"));
  } catch {}
  // 2. Explicit CONTROLLER_HOME override.
  const overrideHome = process.env.CONTROLLER_HOME?.trim();
  if (overrideHome) {
    candidates.push(path.join(overrideHome, "controller-runtime.json"));
  }
  // 3. Platform-default home (issue #223): macOS `Application Support`,
  //    Linux `XDG_STATE_HOME`, otherwise the legacy top-level dot-less dir.
  candidates.push(defaultHomeRuntimeFile(os, path));

  for (const candidate of candidates) {
    try {
      const parsed = JSON.parse(await fs.readFile(candidate, "utf-8"));
      if (parsed && typeof parsed.serverUrl === "string") return parsed.serverUrl;
    } catch {}
  }
  fail("Could not determine the Controller server URL. Is the Controller app running?");
}

// Mirror of `defaultHomeForPlatform` in `server/lib/paths.ts`. The CLI runs
// outside the server process (it may be invoked from a sanitized agent
// shell), so it can't import the server module and re-implements the
// resolution here. Keep the two in sync.
function defaultHomeRuntimeFile(os, path) {
  const platform = process.platform;
  if (platform === "darwin") {
    return path.join(
      os.homedir(),
      "Library",
      "Application Support",
      "Controller",
      "controller-runtime.json",
    );
  }
  if (platform === "linux") {
    const xdg = process.env.XDG_STATE_HOME?.trim();
    const base = xdg && xdg !== "" ? xdg : path.join(os.homedir(), ".local", "state");
    return path.join(base, "Controller", "controller-runtime.json");
  }
  return path.join(
    os.homedir(),
    "coding-orchestrator",
    "controller-runtime.json",
  );
}

async function postJson(serverUrl, route, body) {
  let response;
  try {
    response = await fetch(`${serverUrl.replace(/\/$/, "")}${route}`, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ ...body, cwd: process.cwd() }),
    });
  } catch (error) {
    fail(`Could not reach the orchestrator: ${error?.message ?? error}`);
  }
  let result;
  try {
    result = await response.json();
  } catch {
    fail(`Unexpected response (HTTP ${response.status})`);
  }
  return { response, result };
}

// Server route handlers use method-specific verbs (DELETE for worktree
// removal, etc.), so callers that don't fit the JSON-POST shape need their
// own helper. `runWorktrees delete` goes through here instead of
// `postJson` so the wire request matches `server/routes/worktrees.ts:788`.
async function deleteJson(serverUrl, route) {
  let response;
  try {
    response = await fetch(`${serverUrl.replace(/\/$/, "")}${route}`, {
      method: "DELETE",
    });
  } catch (error) {
    fail(`Could not reach the orchestrator: ${error?.message ?? error}`);
  }
  let result = null;
  // Some DELETE handlers return no body; treat empty/invalid JSON as
  // success-shape and only fail when we have a parsed object with `error`.
  const raw = await response.text();
  if (raw) {
    try {
      result = JSON.parse(raw);
    } catch {
      result = null;
    }
  }
  return { response, result };
}

// --- project resolver (issue #190) ---
//
// `<project>` in the worktrees / sessions surfaces accepts either a project
// id (UUID) or the project's human name. We fetch the project list once and
// match in JS so the server doesn't need a name-lookup endpoint just to make
// the CLI more human-friendly.
export async function resolveProjectId(serverUrl, ref) {
  if (!ref) fail("a <project> (id or name) is required");
  const url = `${serverUrl.replace(/\/$/, "")}/api/projects`;
  let response;
  try {
    response = await fetch(url);
  } catch (error) {
    fail(`Could not reach the orchestrator: ${error?.message ?? error}`);
  }
  if (response.status >= 400) {
    fail(`Failed to list projects (HTTP ${response.status})`);
  }
  let projects;
  try {
    projects = await response.json();
  } catch {
    fail("Unexpected project list response");
  }
  if (!Array.isArray(projects)) {
    fail("Unexpected project list response shape");
  }
  const match = projects.find((p) => p && p.id === ref);
  if (match) return match.id;
  const byName = projects.find((p) => p && p.name === ref);
  if (byName) return byName.id;
  fail(`No project matches "${ref}"`);
}

// --- worktrees surface (issue #190) ---

export function parseWorktrees(argv) {
  const [command, project, ...rest] = argv;
  if (!command) fail(`Unknown worktrees command\n${USAGE}`);
  if (!project) fail(`worktrees ${command} requires a <project>`);
  switch (command) {
    case "list":
      return { project, action: "list" };
    case "create": {
      const name = flagValue(rest, "--name");
      if (!name) fail("worktrees create requires --name <name>");
      const branch = flagValue(rest, "--branch");
      const base = flagValue(rest, "--base");
      return {
        project,
        action: "create",
        body: {
          name,
          ...(branch ? { branch } : {}),
          ...(base ? { baseBranch: base } : {}),
        },
      };
    }
    case "delete": {
      if (!rest[0]) fail("worktrees delete requires a <worktreeId>");
      return { project, action: "delete", worktreeId: rest[0] };
    }
    default:
      fail(`Unknown worktrees command: ${command}\n${USAGE}`);
  }
}

function formatWorktreeRow(worktree) {
  const port = worktree.portOffset != null ? `  portOffset=${worktree.portOffset}` : "";
  const setup =
    worktree.setupExitCode != null
      ? `  setup=${worktree.setupExitCode === 0 ? "ok" : `exit(${worktree.setupExitCode})`}`
      : "";
  return `${worktree.id}  ${worktree.name}  ${worktree.branch ?? "(no branch)"}${worktree.isMain ? "  [main]" : ""}${port}${setup}\n  ${worktree.path}`;
}

export async function runWorktrees(argv, serverUrl) {
  const parsed = parseWorktrees(argv);
  const projectId = await resolveProjectId(serverUrl, parsed.project);
  if (parsed.action === "list") {
    const { response, result } = await getJson(
      serverUrl,
      `/api/projects/${projectId}/worktrees`
    );
    if (response.status >= 400) {
      fail(result?.error ?? `Failed to list worktrees (HTTP ${response.status})`);
    }
    const worktrees = Array.isArray(result) ? result : [];
    if (worktrees.length === 0) {
      process.stdout.write("No worktrees.\n");
      return;
    }
    for (const worktree of worktrees) {
      process.stdout.write(`${formatWorktreeRow(worktree)}\n`);
    }
    return;
  }
  if (parsed.action === "create") {
    const url = `${serverUrl.replace(/\/$/, "")}/api/projects/${projectId}/worktrees`;
    let response;
    try {
      response = await fetch(url, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ ...parsed.body, cwd: process.cwd() }),
      });
    } catch (error) {
      fail(`Could not reach the orchestrator: ${error?.message ?? error}`);
    }
    if (!response.body) {
      fail(`Worktree create failed (HTTP ${response.status})`);
    }
    const reader = response.body.getReader();
    const decoder = new TextDecoder();
    let buffer = "";
    let exitCode = 0;
    let worktree = null;
    let errorText = null;
    for (;;) {
      const { value, done } = await reader.read();
      if (done) break;
      buffer += decoder.decode(value, { stream: true });
      let idx = buffer.indexOf("\n\n");
      while (idx !== -1) {
        const block = buffer.slice(0, idx);
        buffer = buffer.slice(idx + 2);
        const dataLine = block.split("\n").find((line) => line.startsWith("data: "));
        if (dataLine) {
          let event;
          try {
            event = JSON.parse(dataLine.slice(6));
          } catch {
            continue;
          }
          if (event.type === "log" && typeof event.text === "string") {
            process.stdout.write(event.text.endsWith("\n") ? event.text : `${event.text}\n`);
          } else if (event.type === "worktree_created" && event.worktree) {
            worktree = event.worktree;
          } else if (event.type === "error" && typeof event.text === "string") {
            errorText = event.text;
            process.stderr.write(`${event.text}\n`);
          } else if (event.type === "done") {
            exitCode = typeof event.exitCode === "number" ? event.exitCode : 0;
            if (event.worktree) worktree = event.worktree;
          }
        }
        idx = buffer.indexOf("\n\n");
      }
    }
    if (exitCode !== 0) {
      fail(errorText ?? `Worktree create failed (exit ${exitCode})`);
    }
    if (!worktree) {
      fail("Worktree create stream ended without a worktree payload");
    }
    process.stdout.write(`\nCreated worktree ${worktree.name} (id=${worktree.id})\n  ${worktree.path}\n`);
    return;
  }
  if (parsed.action === "delete") {
    const { response, result } = await deleteJson(
      serverUrl,
      `/api/projects/${projectId}/worktrees/${parsed.worktreeId}`
    );
    if (response.status >= 400) {
      fail(result?.error ?? `Failed to delete worktree (HTTP ${response.status})`);
    }
    process.stdout.write("Deleted worktree.\n");
    return;
  }
  fail(`Unknown worktrees action: ${parsed.action}`);
}

async function getJson(serverUrl, route) {
  let response;
  try {
    response = await fetch(`${serverUrl.replace(/\/$/, "")}${route}`);
  } catch (error) {
    fail(`Could not reach the orchestrator: ${error?.message ?? error}`);
  }
  let result;
  try {
    result = await response.json();
  } catch {
    result = null;
  }
  return { response, result };
}

// --- sessions surface (issue #190) ---

export function parseSessions(argv) {
  const [command, project, ...rest] = argv;
  if (!command) fail(`Unknown sessions command\n${USAGE}`);
  if (!project) fail(`sessions ${command} requires a <project>`);
  switch (command) {
    case "start": {
      const worktreeId = flagValue(rest, "--worktree");
      if (!worktreeId) fail("sessions start requires --worktree <worktreeId>");
      const provider = flagValue(rest, "--provider");
      const model = flagValue(rest, "--model");
      const mode = flagValue(rest, "--mode");
      const skill = flagValue(rest, "--skill");
      // `--message` is the last flag: everything after it is the message
      // text, verbatim. This matches the shell idiom of quoting the
      // prompt at the end of the command and avoids forcing the agent
      // to escape whitespace inside the body.
      const messageIdx = rest.indexOf("--message");
      if (messageIdx < 0) {
        fail("sessions start requires --message <text>");
      }
      const trailing = rest.slice(messageIdx + 1);
      // Reject any known option flag that appears after `--message`'s
      // value — otherwise the flag and its argument would be appended to
      // the prompt and silently corrupt the agent's first turn.
      const RESERVED_FLAGS = [
        "--worktree",
        "--provider",
        "--model",
        "--mode",
        "--skill",
      ];
      const offendingFlag = trailing.find((arg) =>
        RESERVED_FLAGS.includes(arg)
      );
      if (offendingFlag) {
        fail(
          `--message must be the last flag on the command line, but found ${offendingFlag} after it. ` +
            `Quote the prompt at the end, e.g. --message "<prompt>" ${offendingFlag === "--worktree" ? "" : "..."}`
        );
      }
      const message = trailing.join(" ").trim();
      if (!message) {
        fail("sessions start requires --message <text>");
      }
      return {
        project,
        action: "start",
        body: {
          worktreeId,
          message,
          ...(provider ? { provider } : {}),
          ...(model ? { model } : {}),
          ...(mode ? { mode } : {}),
          ...(skill ? { skillName: skill } : {}),
        },
      };
    }
    default:
      fail(`Unknown sessions command: ${command}\n${USAGE}`);
  }
}

export async function runSessions(argv, serverUrl) {
  const parsed = parseSessions(argv);
  const projectId = await resolveProjectId(serverUrl, parsed.project);
  if (parsed.action === "start") {
    const { response, result } = await postJson(
      serverUrl,
      `/api/projects/${projectId}/sessions`,
      parsed.body
    );
    if (response.status >= 400) {
      fail(result?.error ?? `Failed to start session (HTTP ${response.status})`);
    }
    const sessionId = result?.sessionId;
    const url = result?.url;
    if (typeof sessionId !== "string" || !sessionId) {
      fail("Server did not return a sessionId");
    }
    process.stdout.write(`Started session ${sessionId}\n`);
    if (typeof url === "string" && url) {
      process.stdout.write(`Open in Controller: ${url}\n`);
    }
    return;
  }
  fail(`Unknown sessions action: ${parsed.action}`);
}

// --- schedules surface (issue #243) ---

// Mirror of `presetToCron` in `server/lib/schedule-cron.ts`. The CLI is
// dependency-free and can't import the server module, so the structured
// `--every` / `--on-day` presets are translated to cron here and sent over
// the wire as a plain cron string. Keep the two in sync.
export function presetToCron({ every, onDay, atHour, atMinute }) {
  const minute = clampInt(atMinute ?? 0, 0, 59);
  const hour = clampInt(atHour ?? 9, 0, 23);
  switch (every) {
    case "minute":
      return "* * * * *";
    case "hour":
      return `${minute} * * * *`;
    case "day":
      return `${minute} ${hour} * * *`;
    case "weekday":
      return `${minute} ${hour} * * 1-5`;
    default:
      if (onDay != null) return `${minute} ${hour} * * ${clampInt(onDay, 0, 6)}`;
      return null;
  }
}

function clampInt(value, min, max) {
  const n = Math.trunc(Number(value));
  if (Number.isNaN(n)) return min;
  return Math.min(max, Math.max(min, n));
}

export function parseSchedules(argv) {
  const [command, project, ...rest] = argv;
  if (!command) fail(`Unknown schedules command\n${USAGE}`);
  if (!project) fail(`schedules ${command} requires a <project>`);
  switch (command) {
    case "list":
      return { project, action: "list", includeDisabled: !rest.includes("--enabled-only") };
    case "show":
      if (!rest[0]) fail("schedules show requires a <scheduleId>");
      return { project, action: "show", scheduleId: rest[0] };
    case "runs":
      if (!rest[0]) fail("schedules runs requires a <scheduleId>");
      return { project, action: "runs", scheduleId: rest[0] };
    case "enable":
      if (!rest[0]) fail("schedules enable requires a <scheduleId>");
      return { project, action: "enable", scheduleId: rest[0] };
    case "disable":
      if (!rest[0]) fail("schedules disable requires a <scheduleId>");
      return { project, action: "disable", scheduleId: rest[0] };
    case "remove":
      if (!rest[0]) fail("schedules remove requires a <scheduleId>");
      return { project, action: "remove", scheduleId: rest[0] };
    case "add": {
      const worktreeId = flagValue(rest, "--worktree");
      if (!worktreeId) fail("schedules add requires --worktree <worktreeId>");
      const prompt = flagValue(rest, "--prompt");
      if (!prompt || !prompt.trim()) fail("schedules add requires --prompt <text>");

      const at = flagValue(rest, "--at");
      const explicitCron = flagValue(rest, "--cron");
      const every = flagValue(rest, "--every");
      const onDay = flagValue(rest, "--on-day");
      // An explicit --cron wins; otherwise derive one from the structured
      // preset flags. Falling through to neither means a one-shot --at.
      let cron = explicitCron ?? null;
      if (!cron && (every || onDay != null)) {
        cron = presetToCron({
          every,
          onDay: onDay != null ? Number(onDay) : undefined,
          atHour: flagValue(rest, "--at-hour"),
          atMinute: flagValue(rest, "--at-minute"),
        });
        if (!cron) fail("schedules add: --every must be minute|hour|day|weekday, or pass --on-day <0-6>");
      }
      if (!cron && !at) {
        fail("schedules add requires --at <iso> (one-shot) or --cron/--every (recurring)");
      }

      const timezone = flagValue(rest, "--timezone");
      const provider = flagValue(rest, "--provider");
      const model = flagValue(rest, "--model");
      const mode = flagValue(rest, "--mode");
      const enabled = flagValue(rest, "--enabled");
      const source = flagValue(rest, "--source");

      return {
        project,
        action: "add",
        body: {
          worktreeId,
          prompt,
          ...(cron ? { cron } : {}),
          ...(at ? { runAt: at } : {}),
          ...(timezone ? { timezone } : {}),
          ...(provider ? { provider } : {}),
          ...(model ? { model } : {}),
          ...(mode ? { mode } : {}),
          ...(enabled != null ? { enabled: enabled === "true" } : {}),
          ...(source ? { source } : {}),
          createdBy: "cli",
        },
      };
    }
    default:
      fail(`Unknown schedules command: ${command}\n${USAGE}`);
  }
}

function formatScheduleRow(schedule) {
  const repeat = schedule.cron ? `cron=${schedule.cron} (${schedule.timezone})` : `at=${schedule.runAt}`;
  const state = schedule.enabled ? "enabled" : "disabled";
  const err = schedule.lastError ? `  lastError=${schedule.lastError}` : "";
  return `${schedule.id}  [${state}]  ${repeat}\n  next=${schedule.nextRunAt}  worktree=${schedule.worktreeId}\n  prompt: ${schedule.prompt}${err}`;
}

export async function runSchedules(argv, serverUrl) {
  const parsed = parseSchedules(argv);
  const projectId = await resolveProjectId(serverUrl, parsed.project);
  const base = `/api/projects/${projectId}/schedules`;

  if (parsed.action === "list") {
    const { response, result } = await getJson(
      serverUrl,
      `${base}?includeDisabled=${parsed.includeDisabled ? "true" : "false"}`
    );
    if (response.status >= 400) {
      fail(result?.error ?? `Failed to list schedules (HTTP ${response.status})`);
    }
    const schedules = Array.isArray(result) ? result : [];
    if (schedules.length === 0) {
      process.stdout.write("No schedules.\n");
      return;
    }
    for (const schedule of schedules) {
      process.stdout.write(`${formatScheduleRow(schedule)}\n`);
    }
    return;
  }

  if (parsed.action === "show") {
    const { response, result } = await getJson(serverUrl, `${base}/${parsed.scheduleId}`);
    if (response.status >= 400) {
      fail(result?.error ?? `Failed to load schedule (HTTP ${response.status})`);
    }
    process.stdout.write(`${JSON.stringify(result, null, 2)}\n`);
    return;
  }

  if (parsed.action === "runs") {
    const { response, result } = await getJson(serverUrl, `${base}/${parsed.scheduleId}/runs`);
    if (response.status >= 400) {
      fail(result?.error ?? `Failed to load runs (HTTP ${response.status})`);
    }
    const runs = Array.isArray(result) ? result : [];
    if (runs.length === 0) {
      process.stdout.write("No runs yet.\n");
      return;
    }
    for (const run of runs) {
      const outcome = run.error ? `error: ${run.error}` : `session=${run.sessionId}`;
      process.stdout.write(`${run.firedAt}  ${outcome}\n`);
    }
    return;
  }

  if (parsed.action === "add") {
    const { response, result } = await postJson(serverUrl, base, parsed.body);
    if (response.status >= 400) {
      fail(result?.error ?? `Failed to add schedule (HTTP ${response.status})`);
    }
    process.stdout.write(`Created schedule ${result.id}\n  next run: ${result.nextRunAt}\n`);
    return;
  }

  if (parsed.action === "enable" || parsed.action === "disable") {
    const { response, result } = await postJson(
      serverUrl,
      `${base}/${parsed.scheduleId}/${parsed.action}`,
      {}
    );
    if (response.status >= 400) {
      fail(result?.error ?? `Failed to ${parsed.action} schedule (HTTP ${response.status})`);
    }
    process.stdout.write(`Schedule ${parsed.action}d.\n`);
    return;
  }

  if (parsed.action === "remove") {
    const { response, result } = await deleteJson(serverUrl, `${base}/${parsed.scheduleId}`);
    if (response.status >= 400) {
      fail(result?.error ?? `Failed to remove schedule (HTTP ${response.status})`);
    }
    process.stdout.write("Removed schedule.\n");
    return;
  }

  fail(`Unknown schedules action: ${parsed.action}`);
}

// --- browser surface (issue #109) ---

function parseBrowser(argv) {
  const [command, ...rest] = argv;
  switch (command) {
    case "open": {
      if (!rest[0]) fail("browser open requires a <url>");
      return { action: "open", params: { url: rest[0] } };
    }
    case "snapshot": {
      // --a11y switches the response shape to a structured accessibility
      // tree (issue #170). The default mode still emits refs in its
      // interactive-elements listing, so the agent only needs --a11y when
      // it wants the full tree.
      const a11y = rest.includes("--a11y");
      const positional = rest.filter((a) => a !== "--a11y");
      return {
        action: "snapshot",
        params: {
          ...(positional[0] ? { selector: positional[0] } : {}),
          a11y,
        },
      };
    }
    case "click": {
      if (!rest[0]) fail("browser click requires a <selector>");
      return { action: "click", params: { selector: rest[0] } };
    }
    case "type": {
      const submit = rest.includes("--submit");
      const positional = rest.filter((a) => a !== "--submit");
      if (!positional[0]) fail("browser type requires a <selector>");
      return { action: "type", params: { selector: positional[0], text: positional.slice(1).join(" "), submit } };
    }
    default:
      fail(`Unknown browser command: ${command ?? ""}\n${USAGE}`);
  }
}

async function runBrowser(argv, serverUrl) {
  const { action, params } = parseBrowser(argv);
  const { response, result } = await postJson(serverUrl, "/api/browser/command", { action, params });
  if (!result || result.ok === false) {
    fail((result && result.error) || `Browser command failed (HTTP ${response.status})`);
  }
  if (action === "snapshot") {
    const header = [result.title, result.url].filter(Boolean).join(" — ");
    if (header) process.stdout.write(`${header}\n\n`);
    process.stdout.write(`${result.text ?? ""}\n`);
    if (result.refCount && result.refCount > 0) {
      process.stdout.write(`\n${result.refCount} ref(s) registered — use \`click ref=e1\` or \`type ref=e1 <text>\` to target them.\n`);
    }
    return;
  }
  const lines = [];
  if (result.summary) lines.push(result.summary);
  if (result.title) lines.push(`Title: ${result.title}`);
  if (result.url) lines.push(`URL: ${result.url}`);
  process.stdout.write(`${lines.join("\n") || "OK"}\n`);
}

// --- terminal surface (issue #261) ---

// Collect positional args, skipping known flags. `valueFlags` consume the
// following token; `boolFlags` are standalone. Lets `snapshot`/`tail` accept
// `--lines`/`--follow` in any position without swallowing the terminal id.
function positionalArgs(rest, valueFlags = [], boolFlags = []) {
  const out = [];
  for (let i = 0; i < rest.length; i += 1) {
    if (boolFlags.includes(rest[i])) continue;
    if (valueFlags.includes(rest[i])) {
      i += 1;
      continue;
    }
    out.push(rest[i]);
  }
  return out;
}

export function parseTerminal(argv) {
  const [command, ...rest] = argv;
  switch (command) {
    case "list":
      return { action: "list", params: {} };
    case "run": {
      const [terminalId, ...commandParts] = rest;
      if (!terminalId) fail("terminal run requires a <terminalId>");
      // Everything after the id is the command, verbatim, so the agent can
      // quote it normally (e.g. `terminal run build "npm run dev"`).
      const command = commandParts.join(" ").trim();
      if (!command) fail("terminal run requires a <command>");
      return { action: "run", params: { terminalId, command } };
    }
    case "snapshot": {
      const positional = positionalArgs(rest, ["--lines"]);
      const terminalId = positional[0];
      if (!terminalId) fail("terminal snapshot requires a <terminalId>");
      const lines = flagValue(rest, "--lines");
      return {
        action: "snapshot",
        params: { terminalId, ...(lines !== undefined ? { lines: Number(lines) } : {}) },
      };
    }
    case "tail": {
      const positional = positionalArgs(rest, [], ["--follow"]);
      const terminalId = positional[0];
      if (!terminalId) fail("terminal tail requires a <terminalId>");
      return { action: "tail", params: { terminalId, follow: rest.includes("--follow") } };
    }
    default:
      fail(`Unknown terminal command: ${command ?? ""}\n${USAGE}`);
  }
}

function printTerminal(action, result) {
  if (action === "list") {
    const terminals = result.terminals ?? [];
    if (terminals.length === 0) {
      process.stdout.write("No terminals are open in this worktree.\n");
      return;
    }
    for (const t of terminals) {
      process.stdout.write(`${t.id}${t.attached ? "  [attached]" : ""}\n`);
    }
    return;
  }
  if (action === "run") {
    process.stdout.write(`Sent to ${result.terminalId}: ${result.sent}\n`);
    return;
  }
  if (action === "snapshot") {
    const text = result.text ?? "";
    process.stdout.write(text.endsWith("\n") || text === "" ? text : `${text}\n`);
    return;
  }
}

export async function runTerminal(argv, serverUrl) {
  const { action, params } = parseTerminal(argv);
  if (action === "tail") {
    await runTerminalTail(serverUrl, params);
    return;
  }
  const { response, result } = await postJson(serverUrl, "/api/terminal/command", { action, params });
  if (!result || result.ok === false) {
    fail((result && result.error) || `Terminal command failed (HTTP ${response.status})`);
  }
  printTerminal(action, result);
}

// `tail` is a streaming response: read chunks as they arrive and write them
// straight through. `--follow` keeps the server stream open until the user
// interrupts the CLI; without it the server ends the stream after a short idle.
async function runTerminalTail(serverUrl, params) {
  let response;
  try {
    response = await fetch(`${serverUrl.replace(/\/$/, "")}/api/terminal/command`, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ action: "tail", params, cwd: process.cwd() }),
    });
  } catch (error) {
    fail(`Could not reach the orchestrator: ${error?.message ?? error}`);
  }
  if (response.status >= 400) {
    let message = `Terminal tail failed (HTTP ${response.status})`;
    try {
      const parsed = await response.json();
      if (parsed && parsed.error) message = parsed.error;
    } catch {}
    fail(message);
  }
  if (!response.body) {
    fail("Terminal tail returned no stream");
  }
  const reader = response.body.getReader();
  const decoder = new TextDecoder();
  for (;;) {
    const { value, done } = await reader.read();
    if (done) break;
    process.stdout.write(decoder.decode(value, { stream: true }));
  }
}

// --- integrations surface (issue #130) ---

function parsePairs(rest, flag) {
  const out = {};
  for (let i = 0; i < rest.length; i += 1) {
    if (rest[i] === flag && rest[i + 1]) {
      const eq = rest[i + 1].indexOf("=");
      if (eq > 0) out[rest[i + 1].slice(0, eq)] = rest[i + 1].slice(eq + 1);
      i += 1;
    }
  }
  return out;
}

function flagValue(rest, flag) {
  const idx = rest.indexOf(flag);
  return idx >= 0 ? rest[idx + 1] : undefined;
}

// Mirror of the `CONNECTION_MODES` and `ACQUISITIONS` enums in
// `server/routes/integrations.ts`. The CLI re-validates these so the agent
// gets immediate feedback on a typo instead of a generic 400; the server
// remains the source of truth (keeps the two in sync).
const INTEGRATION_MODES = ["mcp", "openapi", "rest", "graphql", "cli"];
const INTEGRATION_ACQUISITIONS = [
  "static",
  "basic",
  "oauth",
  "oauth_client_credentials",
  "oauth_dynamic",
  "cloud",
  "hmac",
  "mtls",
];
// Acquisitions that don't carry an attachable credential (the gateway
// reaches them through signing or the transport layer, not a header/query).
const NON_ATTACHABLE_ACQUISITIONS = new Set(["hmac", "mtls", "cloud"]);

export function parseIntegrations(argv) {
  const [command, ...rest] = argv;
  switch (command) {
    case "list":
      // `--all` switches to the registry view (full record, includes disabled).
      // Plain `list` keeps the existing gateway view (active + summary).
      if (rest.includes("--all")) {
        return { action: "registry-list", body: { json: rest.includes("--json") } };
      }
      return { action: "gateway", endpoint: "list", body: {} };
    case "search": {
      const query = rest.join(" ").trim();
      if (!query) fail("integrations search requires a <query>");
      return { action: "gateway", endpoint: "search", body: { query } };
    }
    case "tools":
      if (!rest[0]) fail("integrations tools requires an <integration>");
      return { action: "gateway", endpoint: "tools", body: { integration: rest[0] } };
    case "describe":
      if (!rest[0] || !rest[1]) fail("integrations describe requires <integration> <tool>");
      return { action: "gateway", endpoint: "describe", body: { integration: rest[0], tool: rest[1] } };
    case "call": {
      if (!rest[0] || !rest[1]) fail("integrations call requires <integration> <tool>");
      const json = flagValue(rest, "--json");
      let args = {};
      if (json) {
        try {
          args = JSON.parse(json);
        } catch {
          fail("--json must be valid JSON");
        }
      }
      return { action: "gateway", endpoint: "call", body: { integration: rest[0], tool: rest[1], args } };
    }
    case "request": {
      if (!rest[0] || !rest[1] || !rest[2]) fail("integrations request requires <integration> <METHOD> <path>");
      const data = flagValue(rest, "--data");
      let body = null;
      if (data !== undefined) {
        try {
          body = JSON.parse(data);
        } catch {
          body = data;
        }
      }
      return {
        action: "gateway",
        endpoint: "request",
        body: {
          integration: rest[0],
          method: rest[1],
          path: rest[2],
          query: parsePairs(rest, "--query"),
          headers: parsePairs(rest, "--header"),
          body,
        },
      };
    }
    case "status":
      if (!rest[0]) fail("integrations status requires an <integration>");
      return { action: "gateway", endpoint: "status", body: { integration: rest[0] } };
    case "create":
      // `create` is not a gateway call: it POSTs to the registry endpoint
      // (`/api/integrations/`) and the response shape differs from the
      // gateway actions, so it has its own dispatch path below.
      return { action: "create", body: parseIntegrationCreate(rest) };
    default:
      fail(`Unknown integrations command: ${command ?? ""}\n${USAGE}`);
  }
}

/*
 * Build the registry create body from CLI flags.
 *
 *   controller integrations create --name <name> --transport-mode <mode> \\
 *       [--enabled true|false] \\
 *       [--transport-config k=v]... [--transport-header k=v]... [--transport-query k=v]... \\
 *       [--scheme-acquisition <kind> [--scheme-id <id>] \\
 *           [--scheme-attachment <header|query>:<name> [--scheme-attachment-prefix <prefix>]] \\
 *           [--scheme-config k=v]... \\
 *           [--scheme-secret <value> | --scheme-secret=- | --scheme-secret-file <path>]]...
 *
 * The scheme flags form a small "block" grammar: `--scheme-acquisition`
 * starts a new block and consumes every following `--scheme-*` flag until
 * the next `--scheme-acquisition` or end of args. We split on acquisition
 * boundaries first, then parse each block in isolation. This keeps the
 * parser linear in argv length and means a user mistake in one scheme
 * (e.g. a bad attachment) doesn't lose the others.
 */
function parseIntegrationCreate(rest) {
  // Walk argv once, popping top-level flags + their values into the
  // top-level record, and accumulating any `--scheme-*` arg into a
  // pending list. We treat `--scheme-acquisition` as a hard block
  // boundary: it flushes the pending scheme args into a new block
  // (if the prior block is non-empty) and the next non-scheme arg
  // starts the new block's content. This keeps the parser linear in
  // argv length and means a typo in one scheme doesn't lose the others.
  const name = { value: undefined };
  const transportMode = { value: undefined };
  const enabled = { value: undefined };
  const transport = { config: {}, headers: {}, query: {} };

  // Flags whose `--flag=value` shorthand the parser accepts. The value
  // is whatever follows the first `=`. For `--scheme-secret=-` the value
  // is the literal "-" (a sentinel for stdin), not a missing token — so
  // splitting in argv before the value-consumer runs is exactly the
  // shape we need. Transport pair flags (`--transport-config k=v`, ...)
  // are listed too so users can write `--transport-config=baseUrl=...`
  // in shells that prefer the `=` form.
  const EQUALS_FORM_FLAGS = new Set([
    "--name",
    "--enabled",
    "--transport-mode",
    "--transport-config",
    "--transport-header",
    "--transport-query",
    "--scheme-acquisition",
    "--scheme-id",
    "--scheme-attachment",
    "--scheme-attachment-prefix",
    "--scheme-config",
    "--scheme-secret",
    "--scheme-secret-file",
  ]);
  // `=value` shorthand: when the arg is `--flag=value`, split it so the
  // value-consumer sees the flag and value as separate tokens (just like
  // a shell would have if the user had written them as separate args).
  // `parsePairs`-style flags (transport-config, scheme-config) are
  // handled here too: `--transport-config=baseUrl=https://x` becomes
  // `--transport-config baseUrl=https://x`, and the existing key=value
  // parser does the rest.
  rest = expandEqualsForm(rest, EQUALS_FORM_FLAGS);

  const blocks = [];
  let pending = null;
  let lastTopLevelFlag = null;
  let lastSchemeFlag = null;
  // When set, the next non-`--scheme-*` arg is the acquisition kind for
  // the current scheme block. We track this explicitly so the loop doesn't
  // try to route the acquisition value into the top-level value consumer.
  let nextIsSchemeAcquisition = false;

  for (let i = 0; i < rest.length; i += 1) {
    const arg = rest[i];

    if (arg === "--scheme-acquisition") {
      if (pending) blocks.push(pending);
      pending = { args: [] };
      nextIsSchemeAcquisition = true;
      lastTopLevelFlag = null;
      lastSchemeFlag = null;
      continue;
    }

    if (nextIsSchemeAcquisition) {
      // Acquisition value is positional (not a `--scheme-*` flag).
      pending.args.push(arg);
      nextIsSchemeAcquisition = false;
      lastTopLevelFlag = null;
      lastSchemeFlag = null;
      continue;
    }

    // Scheme value-flag: the arg immediately following a `--scheme-*` flag.
    if (lastSchemeFlag) {
      pending.args.push(lastSchemeFlag);
      pending.args.push(arg);
      lastSchemeFlag = null;
      lastTopLevelFlag = null;
      continue;
    }

    // --scheme-* flags (other than --scheme-acquisition) are routed to the
    // scheme buffer of the current block. A scheme flag without a prior
    // --scheme-acquisition is a user error.
    if (arg.startsWith("--scheme-")) {
      if (!pending) {
        fail(`integrations create: ${arg} appeared before any --scheme-acquisition`);
      }
      // Bool-style scheme flags (none today) would skip the next arg here.
      lastSchemeFlag = arg;
      lastTopLevelFlag = null;
      continue;
    }

    // Top-level value: the arg immediately following a top-level
    // value-flag. We track which flag was just consumed so the splitter
    // doesn't mistake a positional value (e.g. the name) for a flag.
    if (lastTopLevelFlag) {
      assignTopLevelValue(lastTopLevelFlag, arg, {
        name,
        transportMode,
        enabled,
        transport,
      });
      lastTopLevelFlag = null;
      continue;
    }

    // Top-level value-flags.
    if (arg === "--name") { lastTopLevelFlag = "--name"; continue; }
    if (arg === "--transport-mode") { lastTopLevelFlag = "--transport-mode"; continue; }
    if (arg === "--enabled") { lastTopLevelFlag = "--enabled"; continue; }
    if (
      arg === "--transport-config" ||
      arg === "--transport-header" ||
      arg === "--transport-query"
    ) {
      lastTopLevelFlag = arg;
      continue;
    }

    // Unknown flag: surface a clear error so the user can fix it.
    if (arg.startsWith("--")) {
      fail(`integrations create: unexpected flag "${arg}"`);
    }
    fail(`integrations create: unexpected positional argument "${arg}"`);
  }
  if (pending) blocks.push(pending);

  // Validate required fields now that the top-level walk is done.
  const trimmedName = (name.value ?? "").trim();
  if (!trimmedName) fail("integrations create requires --name <name>");
  if (!transportMode.value) fail("integrations create requires --transport-mode <mode>");
  if (!INTEGRATION_MODES.includes(transportMode.value)) {
    fail(
      `integrations create: --transport-mode must be one of ${INTEGRATION_MODES.join("|")} (got "${transportMode.value}")`
    );
  }

  if (blocks.length === 0) {
    fail("integrations create requires at least one --scheme-acquisition <kind> block");
  }

  return {
    name: trimmedName,
    ...(enabled.value !== undefined ? { enabled: enabled.value } : {}),
    transport: {
      mode: transportMode.value,
      config: transport.config,
      headers: transport.headers,
      query: transport.query,
    },
    auth: { schemes: blocks.map(parseSchemeBlock) },
  };
}

/*
 * Accept `--flag=value` as a shorthand for `--flag value` for the
 * documented top-level and scheme flags. The shell hands us a single
 * token (`--scheme-secret=-` is one token, not two), and the value-
 * consumer arms of the main parser only look for the bare flag — so
 * without this expansion the `=` form silently dropped on the floor.
 * For `parsePairs`-style flags (`--transport-config=baseUrl=...`,
 * `--scheme-config=clientId=abc`) the value side still contains a `=`,
 * which is fine: we only split on the first `=` between the known
 * flag and the rest, then the per-flag key=value parser does its job.
 */
function expandEqualsForm(argv, flags) {
  const out = [];
  for (const arg of argv) {
    if (typeof arg !== "string" || !arg.startsWith("--")) { out.push(arg); continue; }
    const eq = arg.indexOf("=");
    if (eq <= 0) { out.push(arg); continue; }
    const flag = arg.slice(0, eq);
    if (!flags.has(flag)) { out.push(arg); continue; }
    out.push(flag);
    out.push(arg.slice(eq + 1));
  }
  return out;
}

function assignTopLevelValue(flag, value, refs) {
  if (flag === "--name") refs.name.value = value;
  else if (flag === "--transport-mode") refs.transportMode.value = value;
  else if (flag === "--enabled") {
    if (value !== "true" && value !== "false") {
      fail('integrations create: --enabled must be "true" or "false"');
    }
    refs.enabled.value = value === "true";
  } else if (flag === "--transport-config") {
    const eq = value.indexOf("=");
    if (eq > 0) refs.transport.config[value.slice(0, eq)] = value.slice(eq + 1);
  } else if (flag === "--transport-header") {
    const eq = value.indexOf("=");
    if (eq > 0) refs.transport.headers[value.slice(0, eq)] = value.slice(eq + 1);
  } else if (flag === "--transport-query") {
    const eq = value.indexOf("=");
    if (eq > 0) refs.transport.query[value.slice(0, eq)] = value.slice(eq + 1);
  }
}

/* Parse a single `--scheme-*` block (the slice after `--scheme-acquisition <kind>`). */
function parseSchemeBlock(block) {
  const args = block.args;
  const acquisition = args[0];
  if (!acquisition) fail("integrations create: --scheme-acquisition requires a <kind>");
  if (!INTEGRATION_ACQUISITIONS.includes(acquisition)) {
    fail(
      `integrations create: --scheme-acquisition must be one of ${INTEGRATION_ACQUISITIONS.join("|")} (got "${acquisition}")`
    );
  }

  // Strip the acquisition token so the rest of the helpers see the
  // scheme-internal flags (--scheme-id, --scheme-attachment, ...).
  const inner = args.slice(1);

  const id = flagValue(inner, "--scheme-id");
  const config = parsePairs(inner, "--scheme-config");

  // `--scheme-attachment` uses the form `header:Authorization` /
  // `query:api_key`. We parse it here so the agent gets a clear error
  // on a malformed value before the server sees it.
  let attachment;
  const rawAttachment = flagValue(inner, "--scheme-attachment");
  if (rawAttachment !== undefined) {
    if (NON_ATTACHABLE_ACQUISITIONS.has(acquisition)) {
      fail(
        `integrations create: --scheme-attachment is not valid for acquisition "${acquisition}" (hmac/mtls/cloud don't carry an attachable credential)`
      );
    }
    const colon = rawAttachment.indexOf(":");
    if (colon <= 0 || colon === rawAttachment.length - 1) {
      fail(
        `integrations create: --scheme-attachment must be in the form <header|query>:<name> (got "${rawAttachment}")`
      );
    }
    const kind = rawAttachment.slice(0, colon);
    const name = rawAttachment.slice(colon + 1);
    if (kind !== "header" && kind !== "query") {
      fail(
        `integrations create: --scheme-attachment kind must be "header" or "query" (got "${kind}")`
      );
    }
    const prefix = flagValue(inner, "--scheme-attachment-prefix");
    attachment = { kind, name, ...(prefix ? { prefix } : {}) };
  }

  // Secret resolution: --scheme-secret-file / --scheme-secret=- (stdin) /
  // --scheme-secret <value>. The file/stdin reads are deferred to the
  // async run path so this parser stays synchronous; the dispatcher reads
  // them after parseIntegrations returns and patches the secret onto the
  // body before the POST.
  const secretValue = flagValue(inner, "--scheme-secret");
  const secretFile = flagValue(inner, "--scheme-secret-file");
  if (secretValue !== undefined && secretFile !== undefined) {
    fail(
      "integrations create: --scheme-secret and --scheme-secret-file are mutually exclusive on a single scheme block"
    );
  }
  let secret;
  let secretSource = null;
  if (secretFile !== undefined) {
    secret = ""; // sentinel: dispatcher reads the file
    secretSource = { kind: "file", path: secretFile };
  } else if (secretValue !== undefined) {
    if (secretValue === "-") {
      secret = "";
      secretSource = { kind: "stdin" };
    } else {
      secret = secretValue;
    }
  }

  return {
    ...(id ? { id } : {}),
    acquisition,
    ...(attachment ? { attachment } : {}),
    ...(Object.keys(config).length > 0 ? { config } : {}),
    ...(secretSource || secret !== undefined ? { secret } : {}),
    ...(secretSource ? { __secretSource: secretSource } : {}),
  };
}

export function printIntegrations(command, result) {
  if (command === "list") {
    const conns = result.connections ?? [];
    if (conns.length === 0) return process.stdout.write("No integrations are enabled for this session.\n");
    for (const c of conns) process.stdout.write(`${c.name}  [${c.mode}/${c.kind}]  ${c.summary}\n`);
    return;
  }
  if (command === "list --all") {
    // The registry endpoint returns the connection array directly (not
    // wrapped in `{ connections: [...] }` like the gateway does), so
    // accept both shapes for forward compatibility.
    const conns = Array.isArray(result?.connections)
      ? result.connections
      : Array.isArray(result)
      ? result
      : [];
    if (conns.length === 0) return process.stdout.write("No integrations are configured.\n");
    if (result.json) {
      process.stdout.write(`${JSON.stringify(conns, null, 2)}\n`);
      return;
    }
    for (const c of conns) {
      const state = c.enabled ? "enabled" : "disabled";
      process.stdout.write(`${c.id}  ${c.name}  [${state}]  ${c.transport?.mode ?? "?"}\n`);
    }
    return;
  }
  if (command === "search") {
    const matches = result.matches ?? [];
    if (matches.length === 0) return process.stdout.write("No matching tools.\n");
    for (const m of matches) process.stdout.write(`${m.integration}  ${m.tool} — ${m.summary}\n`);
    return;
  }
  if (command === "tools") {
    if (result.note) process.stdout.write(`${result.note}\n`);
    for (const t of result.tools ?? []) process.stdout.write(`${t.tool} — ${t.summary}\n`);
    return;
  }
  if (command === "describe") return process.stdout.write(`${JSON.stringify(result, null, 2)}\n`);
  if (command === "status") {
    process.stdout.write(`${result.message}\n`);
    if (result.ok === false) process.exit(2);
    return;
  }
  // call / request
  if (result.ok === false) {
    if (result.reauth) {
      process.stdout.write(`Re-authentication needed: ${result.reauth.message}\n`);
      process.exit(3);
    }
    fail(result.error || "Request failed");
  }
  if (result.result !== undefined) return process.stdout.write(`${JSON.stringify(result.result, null, 2)}\n`);
  process.stdout.write(`HTTP ${result.status} ${result.statusText}\n`);
  if (result.body) process.stdout.write(`${result.body}\n`);
  if (result.truncated) process.stdout.write("\n[output truncated]\n");
}

// --- skills surface (issue #134) ---

function parseSkills(argv) {
  const [command, ...rest] = argv;
  switch (command) {
    case "list":
      return { endpoint: "list", body: {} };
    case "search": {
      const query = rest.join(" ").trim();
      if (!query) fail("skills search requires a <query>");
      return { endpoint: "search", body: { query } };
    }
    case "describe":
      if (!rest[0]) fail("skills describe requires a <name>");
      return { endpoint: "describe", body: { name: rest[0] } };
    case "activate":
      if (!rest[0]) fail("skills activate requires a <name>");
      return { endpoint: "activate", body: { name: rest[0] } };
    case "import-discover":
      return { endpoint: "import-discover", body: {} };
    case "import":
      return { endpoint: "import", body: parseImportSelections(rest) };
    default:
      fail(`Unknown skills command: ${command ?? ""}\n${USAGE}`);
  }
}

function parseImportSelections(rest) {
  // `--all` is a CLI convenience: the server treats an empty `selections`
  // array as "nothing to import", so when `--all` is set we return a marker
  // and let `runSkills` fetch the discover list and build the selections
  // before hitting the import endpoint. The `--overwrite` flag still
  // applies in bulk mode, so we record it on the marker and forward it to
  // every generated selection below.
  if (rest.includes("--all")) {
    return { __all: true, overwrite: rest.includes("--overwrite") };
  }
  const provider = flagValue(rest, "--provider");
  const source = flagValue(rest, "--source");
  const scope = flagValue(rest, "--scope") ?? "user";
  if (!provider || !source) {
    fail("skills import requires --provider <id> and --source <path> (or --all)");
  }
  const overwrite = rest.includes("--overwrite");
  return {
    selections: [{ providerId: provider, sourcePath: source, scope, overwrite }],
  };
}

function printSkills(command, result) {
  if (command === "list") {
    const skills = result.skills ?? [];
    if (skills.length === 0) return process.stdout.write("No unified skills are configured.\n");
    for (const s of skills) process.stdout.write(`${s.name} — ${s.description}\n`);
    return;
  }
  if (command === "search") {
    const skills = result.skills ?? [];
    if (skills.length === 0) return process.stdout.write("No matching unified skills.\n");
    for (const s of skills) process.stdout.write(`${s.name} — ${s.description}\n`);
    return;
  }
  if (command === "describe") {
    process.stdout.write(result.body ?? "");
    return;
  }
  if (command === "activate") {
    process.stdout.write(`${result.message ?? "Skill activated for the next turn."}\n`);
    return;
  }
  if (command === "import-discover") {
    const skills = result.skills ?? [];
    if (skills.length === 0) return process.stdout.write("No importable per-agent skills found.\n");
    for (const s of skills) {
      const project = s.projectPath ? `  (project: ${s.projectPath})` : "";
      process.stdout.write(`${s.providerId}/${s.scope}  ${s.name} — ${s.description}${project}\n`);
      // Print the source path so the single-skill import flow
      // (`import --provider <id> --source <path>`) has the value it needs.
      process.stdout.write(`  source: ${s.sourcePath}\n`);
    }
    return;
  }
  if (command === "import") {
    const results = result.results ?? [];
    if (results.length === 0) return process.stdout.write("Nothing to import.\n");
    for (const r of results) {
      const status = r.status.toUpperCase().padEnd(8);
      const where = `${r.providerId}/${r.scope}`;
      const name = r.name || "(unknown)";
      const tail = r.reason ? ` — ${r.reason}` : "";
      process.stdout.write(`${status} ${where.padEnd(12)} ${name}${tail}\n`);
    }
    return;
  }
}

async function runSkills(argv, serverUrl) {
  const { endpoint, body } = parseSkills(argv);
  let effectiveBody = body;
  // `--all` is a CLI convenience: fetch the discover list, then import every
  // entry. Skips/failures are surfaced per-skill by the server response.
  if (body && body.__all) {
    const discover = await postJson(serverUrl, "/api/skills/import-discover", {});
    if (discover.response.status >= 400) {
      fail(discover.result?.error ?? `Import discovery failed (HTTP ${discover.response.status})`);
    }
    const selections = (discover.result?.skills ?? []).map((s) => ({
      providerId: s.providerId,
      sourcePath: s.sourcePath,
      scope: s.scope,
      overwrite: body.overwrite === true,
    }));
    effectiveBody = { selections };
  }
  const { response, result } = await postJson(serverUrl, `/api/skills/${endpoint}`, effectiveBody);
  if (response.status >= 400 && result && result.error) fail(result.error);
  printSkills(argv[0], result);
}

// --- integrations dispatcher (issue #178) ---
//
// Bridges `parseIntegrations` to the right wire call. There are three
// action kinds today:
//   - `gateway`         POST /api/integrations/gateway/<endpoint>   (list/search/call/...)
//   - `registry-list`   GET  /api/integrations/                    (list --all)
//   - `create`          POST /api/integrations/                    (create)
//
// `gateway` is the historical surface; the registry routes are mounted on
// `/api/integrations/` (same one the Settings dialog uses) and have a
// different request/response shape, so they get their own branch.
export async function runIntegrations(argv, serverUrl) {
  const parsed = parseIntegrations(argv);
  if (parsed.action === "gateway") {
    const { response, result } = await postJson(
      serverUrl,
      `/api/integrations/gateway/${parsed.endpoint}`,
      parsed.body
    );
    if (response.status >= 400 && result && result.error) fail(result.error);
    printIntegrations(argv[0], result);
    return;
  }
  if (parsed.action === "registry-list") {
    const { response, result } = await getJson(serverUrl, "/api/integrations/");
    if (response.status >= 400) {
      fail(result?.error ?? `Failed to list integrations (HTTP ${response.status})`);
    }
    // The registry endpoint returns the connection array directly (not
    // wrapped in `{ connections: [...] }` like the gateway does). Wrap it
    // here so `printIntegrations` can use a single shape and the `--json`
    // flag renders the array rather than the full HTTP envelope.
    const conns = Array.isArray(result) ? result : result?.connections ?? [];
    printIntegrations("list --all", { connections: conns, json: parsed.body.json });
    return;
  }
  if (parsed.action === "create") {
    await runIntegrationsCreate(serverUrl, parsed.body);
    return;
  }
  fail(`Unknown integrations action: ${parsed.action}`);
}

/*
 * Resolve secret sources in the create body and POST to the registry.
 *
 * The synchronous parser leaves a `__secretSource` sentinel on each scheme
 * whose value must be read at submit time (file or stdin). We do that here
 * because the parser must stay synchronous and the file read is async. After
 * resolution, we strip the sentinel so it never reaches the wire.
 */
async function runIntegrationsCreate(serverUrl, body) {
  const schemes = body?.auth?.schemes;
  if (Array.isArray(schemes)) {
    for (const scheme of schemes) {
      if (!scheme || !scheme.__secretSource) continue;
      const source = scheme.__secretSource;
      delete scheme.__secretSource;
      if (source.kind === "file") {
        try {
          const fs = await import("node:fs/promises");
          scheme.secret = (await fs.readFile(source.path, "utf-8")).replace(/\r?\n$/, "");
        } catch (error) {
          fail(`Could not read --scheme-secret-file ${source.path}: ${error?.message ?? error}`);
        }
      } else if (source.kind === "stdin") {
        // Read stdin until EOF, strip a single trailing newline so the common
        // `echo "$TOKEN" | controller ...` idiom doesn't pick up an extra \n.
        // Real stdin yields Buffer chunks; `Readable.from([...])` in tests
        // can yield either, so coerce to Buffer here to keep the concat path
        // uniform.
        const chunks = [];
        for await (const chunk of process.stdin) {
          chunks.push(typeof chunk === "string" ? Buffer.from(chunk) : chunk);
        }
        scheme.secret = Buffer.concat(chunks).toString("utf-8").replace(/\r?\n$/, "");
      }
    }
  }
  const { response, result } = await postJson(serverUrl, "/api/integrations/", body);
  if (response.status >= 400) {
    fail(result?.error ?? `Failed to create integration (HTTP ${response.status})`);
  }
  const name = result?.name ?? body?.name ?? "(unnamed)";
  const id = result?.id ?? "(no id)";
  const mode = result?.transport?.mode ?? body?.transport?.mode ?? "?";
  const state = result?.enabled === false ? "  [disabled]" : "";
  process.stdout.write(`Created integration ${name} (id=${id}) [mode=${mode}]${state}\n`);
}

// `create` does not fit the `parseSkills` shape because it takes
// `--name` / `--description` / `--body` / `--body-file` flags and reads
// from disk when given a body file. It also POSTs to a different endpoint
// that returns `{ ok, skill }` instead of the bare payload.
async function readBodyFile(path) {
  const fs = await import("node:fs/promises");
  return fs.readFile(path, "utf-8");
}

function parseFlags(rest, flags) {
  const out = {};
  for (let i = 0; i < rest.length; i += 1) {
    if (flags.includes(rest[i]) && rest[i + 1] !== undefined) {
      out[rest[i].slice(2)] = rest[i + 1];
      i += 1;
    }
  }
  return out;
}

async function runSkillsCreate(rest, serverUrl) {
  const flags = parseFlags(rest, ["--name", "--description", "--body", "--body-file"]);
  if (!flags.name) fail("skills create requires --name <name>");
  if (!flags.description) fail("skills create requires --description <description>");
  if (flags["body-file"] && flags.body) {
    fail("skills create accepts only one of --body or --body-file");
  }
  let body = "";
  if (flags["body-file"]) {
    try {
      body = await readBodyFile(flags["body-file"]);
    } catch (error) {
      fail(`Could not read body file: ${error?.message ?? error}`);
    }
  } else if (flags.body !== undefined) {
    body = flags.body;
  }
  const { response, result } = await postJson(serverUrl, "/api/skills/create", {
    name: flags.name,
    description: flags.description,
    body,
  });
  if (!result || result.ok === false) {
    fail((result && result.error) || `Skill create failed (HTTP ${response.status})`);
  }
  const skill = result.skill ?? {};
  process.stdout.write(`Created skill "${skill.name}" at ${skill.path}\n`);
}

async function main() {
  const [surface, ...rest] = process.argv.slice(2);
  if (!surface || surface === "-h" || surface === "--help") {
    process.stdout.write(`${USAGE}\n`);
    process.exit(surface ? 0 : 1);
  }
  if (
    surface !== "browser" &&
    surface !== "terminal" &&
    surface !== "integrations" &&
    surface !== "skills" &&
    surface !== "worktrees" &&
    surface !== "sessions" &&
    surface !== "schedules"
  ) {
    fail(`Unknown surface: ${surface}\n${USAGE}`);
  }
  const serverUrl = await getServerUrl();
  if (surface === "browser") await runBrowser(rest, serverUrl);
  else if (surface === "terminal") await runTerminal(rest, serverUrl);
  else if (surface === "integrations") await runIntegrations(rest, serverUrl);
  else if (surface === "skills") {
    if (rest[0] === "create") {
      await runSkillsCreate(rest.slice(1), serverUrl);
    } else {
      await runSkills(rest, serverUrl);
    }
  } else if (surface === "worktrees") {
    await runWorktrees(rest, serverUrl);
  } else if (surface === "sessions") {
    await runSessions(rest, serverUrl);
  } else if (surface === "schedules") {
    await runSchedules(rest, serverUrl);
  }
}

if (isMain) {
  main().catch((error) => fail(error?.message ?? String(error)));
}
