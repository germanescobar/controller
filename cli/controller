#!/usr/bin/env node
/*
 * controller — unified Controller CLI for agents (issues #109, #130, #134).
 *
 * One entry point with per-surface subcommands:
 *   controller browser <action> ...        Drive the in-app preview browser.
 *   controller integrations <action> ...   Use configured third-party services.
 *   controller skills <action> ...           Search and activate unified skills.
 *
 * Invoked by its absolute install path (`~/coding-orchestrator/bin/controller`)
 * because sanitized/login shells drop injected env vars and PATH entries. The
 * server URL comes from CONTROLLER_SERVER_URL when present, otherwise from the
 * runtime file the server publishes next to this script. Dependency-free (no
 * build step) so it runs identically in dev and packaged builds.
 */

const USAGE = `Usage:
  controller browser open <url>
  controller browser snapshot [selector]
  controller browser click <selector>
  controller browser type <selector> <text> [--submit]

  controller integrations list
  controller integrations search <query>
  controller integrations tools <integration>
  controller integrations describe <integration> <tool>
  controller integrations call <integration> <tool> [--json '{"key":"value"}']
  controller integrations request <integration> <METHOD> <path> [--query k=v]... [--header k=v]... [--data '<body>']
  controller integrations status <integration>

  controller skills list
  controller skills search <query>
  controller skills describe <name>
  controller skills activate <name>
  controller skills create --name <name> --description <description> [--body <body>] [--body-file <path>]
  controller skills import-discover
  controller skills import [--provider <id>] [--source <path>] [--scope <scope>] [--overwrite]... [--all]`;

function fail(message) {
  process.stderr.write(`Error: ${message}\n`);
  process.exit(1);
}

async function getServerUrl() {
  if (process.env.CONTROLLER_SERVER_URL) return process.env.CONTROLLER_SERVER_URL;
  const os = await import("node:os");
  const path = await import("node:path");
  const fs = await import("node:fs/promises");

  const candidates = [];
  try {
    const scriptPath = await fs.realpath(process.argv[1]);
    candidates.push(path.join(path.dirname(scriptPath), "..", "controller-runtime.json"));
  } catch {}
  if (process.env.CODING_ORCHESTRATOR_HOME) {
    candidates.push(path.join(process.env.CODING_ORCHESTRATOR_HOME, "controller-runtime.json"));
  }
  candidates.push(path.join(os.homedir(), "coding-orchestrator", "controller-runtime.json"));

  for (const candidate of candidates) {
    try {
      const parsed = JSON.parse(await fs.readFile(candidate, "utf-8"));
      if (parsed && typeof parsed.serverUrl === "string") return parsed.serverUrl;
    } catch {}
  }
  fail("Could not determine the Controller server URL. Is the Controller app running?");
}

async function postJson(serverUrl, route, body) {
  let response;
  try {
    response = await fetch(`${serverUrl.replace(/\/$/, "")}${route}`, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ ...body, cwd: process.cwd() }),
    });
  } catch (error) {
    fail(`Could not reach the orchestrator: ${error?.message ?? error}`);
  }
  let result;
  try {
    result = await response.json();
  } catch {
    fail(`Unexpected response (HTTP ${response.status})`);
  }
  return { response, result };
}

// --- browser surface (issue #109) ---

function parseBrowser(argv) {
  const [command, ...rest] = argv;
  switch (command) {
    case "open": {
      if (!rest[0]) fail("browser open requires a <url>");
      return { action: "open", params: { url: rest[0] } };
    }
    case "snapshot":
      return { action: "snapshot", params: rest[0] ? { selector: rest[0] } : {} };
    case "click": {
      if (!rest[0]) fail("browser click requires a <selector>");
      return { action: "click", params: { selector: rest[0] } };
    }
    case "type": {
      const submit = rest.includes("--submit");
      const positional = rest.filter((a) => a !== "--submit");
      if (!positional[0]) fail("browser type requires a <selector>");
      return { action: "type", params: { selector: positional[0], text: positional.slice(1).join(" "), submit } };
    }
    default:
      fail(`Unknown browser command: ${command ?? ""}\n${USAGE}`);
  }
}

async function runBrowser(argv, serverUrl) {
  const { action, params } = parseBrowser(argv);
  const { response, result } = await postJson(serverUrl, "/api/browser/command", { action, params });
  if (!result || result.ok === false) {
    fail((result && result.error) || `Browser command failed (HTTP ${response.status})`);
  }
  if (action === "snapshot") {
    const header = [result.title, result.url].filter(Boolean).join(" — ");
    if (header) process.stdout.write(`${header}\n\n`);
    process.stdout.write(`${result.text ?? ""}\n`);
    return;
  }
  const lines = [];
  if (result.summary) lines.push(result.summary);
  if (result.title) lines.push(`Title: ${result.title}`);
  if (result.url) lines.push(`URL: ${result.url}`);
  process.stdout.write(`${lines.join("\n") || "OK"}\n`);
}

// --- integrations surface (issue #130) ---

function parsePairs(rest, flag) {
  const out = {};
  for (let i = 0; i < rest.length; i += 1) {
    if (rest[i] === flag && rest[i + 1]) {
      const eq = rest[i + 1].indexOf("=");
      if (eq > 0) out[rest[i + 1].slice(0, eq)] = rest[i + 1].slice(eq + 1);
      i += 1;
    }
  }
  return out;
}

function flagValue(rest, flag) {
  const idx = rest.indexOf(flag);
  return idx >= 0 ? rest[idx + 1] : undefined;
}

function parseIntegrations(argv) {
  const [command, ...rest] = argv;
  switch (command) {
    case "list":
      return { endpoint: "list", body: {} };
    case "search": {
      const query = rest.join(" ").trim();
      if (!query) fail("integrations search requires a <query>");
      return { endpoint: "search", body: { query } };
    }
    case "tools":
      if (!rest[0]) fail("integrations tools requires an <integration>");
      return { endpoint: "tools", body: { integration: rest[0] } };
    case "describe":
      if (!rest[0] || !rest[1]) fail("integrations describe requires <integration> <tool>");
      return { endpoint: "describe", body: { integration: rest[0], tool: rest[1] } };
    case "call": {
      if (!rest[0] || !rest[1]) fail("integrations call requires <integration> <tool>");
      const json = flagValue(rest, "--json");
      let args = {};
      if (json) {
        try {
          args = JSON.parse(json);
        } catch {
          fail("--json must be valid JSON");
        }
      }
      return { endpoint: "call", body: { integration: rest[0], tool: rest[1], args } };
    }
    case "request": {
      if (!rest[0] || !rest[1] || !rest[2]) fail("integrations request requires <integration> <METHOD> <path>");
      const data = flagValue(rest, "--data");
      let body = null;
      if (data !== undefined) {
        try {
          body = JSON.parse(data);
        } catch {
          body = data;
        }
      }
      return {
        endpoint: "request",
        body: {
          integration: rest[0],
          method: rest[1],
          path: rest[2],
          query: parsePairs(rest, "--query"),
          headers: parsePairs(rest, "--header"),
          body,
        },
      };
    }
    case "status":
      if (!rest[0]) fail("integrations status requires an <integration>");
      return { endpoint: "status", body: { integration: rest[0] } };
    default:
      fail(`Unknown integrations command: ${command ?? ""}\n${USAGE}`);
  }
}

function printIntegrations(command, result) {
  if (command === "list") {
    const conns = result.connections ?? [];
    if (conns.length === 0) return process.stdout.write("No integrations are enabled for this session.\n");
    for (const c of conns) process.stdout.write(`${c.name}  [${c.mode}/${c.kind}]  ${c.summary}\n`);
    return;
  }
  if (command === "search") {
    const matches = result.matches ?? [];
    if (matches.length === 0) return process.stdout.write("No matching tools.\n");
    for (const m of matches) process.stdout.write(`${m.integration}  ${m.tool} — ${m.summary}\n`);
    return;
  }
  if (command === "tools") {
    if (result.note) process.stdout.write(`${result.note}\n`);
    for (const t of result.tools ?? []) process.stdout.write(`${t.tool} — ${t.summary}\n`);
    return;
  }
  if (command === "describe") return process.stdout.write(`${JSON.stringify(result, null, 2)}\n`);
  if (command === "status") {
    process.stdout.write(`${result.message}\n`);
    if (result.ok === false) process.exit(2);
    return;
  }
  // call / request
  if (result.ok === false) {
    if (result.reauth) {
      process.stdout.write(`Re-authentication needed: ${result.reauth.message}\n`);
      process.exit(3);
    }
    fail(result.error || "Request failed");
  }
  if (result.result !== undefined) return process.stdout.write(`${JSON.stringify(result.result, null, 2)}\n`);
  process.stdout.write(`HTTP ${result.status} ${result.statusText}\n`);
  if (result.body) process.stdout.write(`${result.body}\n`);
  if (result.truncated) process.stdout.write("\n[output truncated]\n");
}

// --- skills surface (issue #134) ---

function parseSkills(argv) {
  const [command, ...rest] = argv;
  switch (command) {
    case "list":
      return { endpoint: "list", body: {} };
    case "search": {
      const query = rest.join(" ").trim();
      if (!query) fail("skills search requires a <query>");
      return { endpoint: "search", body: { query } };
    }
    case "describe":
      if (!rest[0]) fail("skills describe requires a <name>");
      return { endpoint: "describe", body: { name: rest[0] } };
    case "activate":
      if (!rest[0]) fail("skills activate requires a <name>");
      return { endpoint: "activate", body: { name: rest[0] } };
    case "import-discover":
      return { endpoint: "import-discover", body: {} };
    case "import":
      return { endpoint: "import", body: parseImportSelections(rest) };
    default:
      fail(`Unknown skills command: ${command ?? ""}\n${USAGE}`);
  }
}

function parseImportSelections(rest) {
  // `--all` is a CLI convenience: the server treats an empty `selections`
  // array as "nothing to import", so when `--all` is set we return a marker
  // and let `runSkills` fetch the discover list and build the selections
  // before hitting the import endpoint. The `--overwrite` flag still
  // applies in bulk mode, so we record it on the marker and forward it to
  // every generated selection below.
  if (rest.includes("--all")) {
    return { __all: true, overwrite: rest.includes("--overwrite") };
  }
  const provider = flagValue(rest, "--provider");
  const source = flagValue(rest, "--source");
  const scope = flagValue(rest, "--scope") ?? "user";
  if (!provider || !source) {
    fail("skills import requires --provider <id> and --source <path> (or --all)");
  }
  const overwrite = rest.includes("--overwrite");
  return {
    selections: [{ providerId: provider, sourcePath: source, scope, overwrite }],
  };
}

function printSkills(command, result) {
  if (command === "list") {
    const skills = result.skills ?? [];
    if (skills.length === 0) return process.stdout.write("No unified skills are configured.\n");
    for (const s of skills) process.stdout.write(`${s.name} — ${s.description}\n`);
    return;
  }
  if (command === "search") {
    const skills = result.skills ?? [];
    if (skills.length === 0) return process.stdout.write("No matching unified skills.\n");
    for (const s of skills) process.stdout.write(`${s.name} — ${s.description}\n`);
    return;
  }
  if (command === "describe") {
    process.stdout.write(result.body ?? "");
    return;
  }
  if (command === "activate") {
    process.stdout.write(`${result.message ?? "Skill activated for the next turn."}\n`);
    return;
  }
  if (command === "import-discover") {
    const skills = result.skills ?? [];
    if (skills.length === 0) return process.stdout.write("No importable per-agent skills found.\n");
    for (const s of skills) {
      const project = s.projectPath ? `  (project: ${s.projectPath})` : "";
      process.stdout.write(`${s.providerId}/${s.scope}  ${s.name} — ${s.description}${project}\n`);
    }
    return;
  }
  if (command === "import") {
    const results = result.results ?? [];
    if (results.length === 0) return process.stdout.write("Nothing to import.\n");
    for (const r of results) {
      const status = r.status.toUpperCase().padEnd(8);
      const where = `${r.providerId}/${r.scope}`;
      const name = r.name || "(unknown)";
      const tail = r.reason ? ` — ${r.reason}` : "";
      process.stdout.write(`${status} ${where.padEnd(12)} ${name}${tail}\n`);
    }
    return;
  }
}

async function runSkills(argv, serverUrl) {
  const { endpoint, body } = parseSkills(argv);
  let effectiveBody = body;
  // `--all` is a CLI convenience: fetch the discover list, then import every
  // entry. Skips/failures are surfaced per-skill by the server response.
  if (body && body.__all) {
    const discover = await postJson(serverUrl, "/api/skills/import-discover", {});
    if (discover.response.status >= 400) {
      fail(discover.result?.error ?? `Import discovery failed (HTTP ${discover.response.status})`);
    }
    const selections = (discover.result?.skills ?? []).map((s) => ({
      providerId: s.providerId,
      sourcePath: s.sourcePath,
      scope: s.scope,
      overwrite: body.overwrite === true,
    }));
    effectiveBody = { selections };
  }
  const { response, result } = await postJson(serverUrl, `/api/skills/${endpoint}`, effectiveBody);
  if (response.status >= 400 && result && result.error) fail(result.error);
  printSkills(argv[0], result);
}

// `create` does not fit the `parseSkills` shape because it takes
// `--name` / `--description` / `--body` / `--body-file` flags and reads
// from disk when given a body file. It also POSTs to a different endpoint
// that returns `{ ok, skill }` instead of the bare payload.
async function readBodyFile(path) {
  const fs = await import("node:fs/promises");
  return fs.readFile(path, "utf-8");
}

function parseFlags(rest, flags) {
  const out = {};
  for (let i = 0; i < rest.length; i += 1) {
    if (flags.includes(rest[i]) && rest[i + 1] !== undefined) {
      out[rest[i].slice(2)] = rest[i + 1];
      i += 1;
    }
  }
  return out;
}

async function runSkillsCreate(rest, serverUrl) {
  const flags = parseFlags(rest, ["--name", "--description", "--body", "--body-file"]);
  if (!flags.name) fail("skills create requires --name <name>");
  if (!flags.description) fail("skills create requires --description <description>");
  if (flags["body-file"] && flags.body) {
    fail("skills create accepts only one of --body or --body-file");
  }
  let body = "";
  if (flags["body-file"]) {
    try {
      body = await readBodyFile(flags["body-file"]);
    } catch (error) {
      fail(`Could not read body file: ${error?.message ?? error}`);
    }
  } else if (flags.body !== undefined) {
    body = flags.body;
  }
  const { response, result } = await postJson(serverUrl, "/api/skills/create", {
    name: flags.name,
    description: flags.description,
    body,
  });
  if (!result || result.ok === false) {
    fail((result && result.error) || `Skill create failed (HTTP ${response.status})`);
  }
  const skill = result.skill ?? {};
  process.stdout.write(`Created skill "${skill.name}" at ${skill.path}\n`);
}

async function main() {
  const [surface, ...rest] = process.argv.slice(2);
  if (!surface || surface === "-h" || surface === "--help") {
    process.stdout.write(`${USAGE}\n`);
    process.exit(surface ? 0 : 1);
  }
  if (surface !== "browser" && surface !== "integrations" && surface !== "skills") {
    fail(`Unknown surface: ${surface}\n${USAGE}`);
  }
  const serverUrl = await getServerUrl();
  if (surface === "browser") await runBrowser(rest, serverUrl);
  else if (surface === "integrations") await runIntegrations(rest, serverUrl);
  else if (surface === "skills") {
    if (rest[0] === "create") {
      await runSkillsCreate(rest.slice(1), serverUrl);
    } else {
      await runSkills(rest, serverUrl);
    }
  }
}

main().catch((error) => fail(error?.message ?? String(error)));
