#!/usr/bin/env node
/*
 * controller-browser — deprecated alias for `controller browser` (issue #109).
 *
 * The browser CLI was unified into the single `controller` CLI (issue #130).
 * This shim forwards to `controller browser ...` so anything still invoking the
 * old absolute path keeps working. Prefer `controller browser ...` directly.
 *
 * Uses only dynamic import() and resolves the sibling `controller` from its own
 * path, so it runs identically whether the runtime treats it as ESM (dev, where
 * package.json is type:module) or CommonJS (installed under ~/coding-orchestrator
 * where there is no package.json).
 */

async function main() {
  const path = await import("node:path");
  const fs = await import("node:fs/promises");
  const { spawnSync } = await import("node:child_process");

  let dir;
  try {
    dir = path.dirname(await fs.realpath(process.argv[1]));
  } catch {
    dir = path.dirname(process.argv[1]);
  }
  const target = path.join(dir, "controller");
  const result = spawnSync(process.execPath, [target, "browser", ...process.argv.slice(2)], {
    stdio: "inherit",
  });
  process.exit(result.status ?? 1);
}

main();
