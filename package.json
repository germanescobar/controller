    "@xterm/xterm": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "diff": "^9.0.0",
    "express": "^5.1.0",
    "highlight.js": "^11.11.1",
    "lucide-react": "^1.7.0",
    "next-themes": "^0.4.6",
    "node-pty": "^1.2.0-beta.12",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.1.2",
    "sonner": "^2.0.7",
