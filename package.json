{
  "name": "coding-orchestrator",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch --env-file-if-exists=.env.local server/index.ts",
